   "source": [
    "# ── Helpers ──────────────────────────────────────────────────────────\n",
    "\n",
    "def get_elo(team):\n",
    "    \"\"\"Look up a team's current ELO.\"\"\"\n",
    "    row = wc_elo[wc_elo['team'] == team]\n",
    "    return row['elo'].values[0] if len(row) else 1500.0\n",
    "\n",
    "def predict_probs(home, away, neutral=True):\n",
    "    \"\"\"Return (p_home_win, p_draw, p_away_win) using the trained model.\"\"\"\n",
    "    home_elo  = get_elo(home)\n",
    "    away_elo  = get_elo(away)\n",
    "    elo_diff  = home_elo - away_elo\n",
    "    # Form diff unavailable for future matches — set to 0\n",
    "    form_diff = 0.0\n",
    "    X = scaler.transform([[elo_diff, form_diff, int(neutral), 1.0]])\n",
    "    probs = lr.predict_proba(X)[0]\n",
    "    # lr.classes_ = [-1, 0, 1] → [away_win, draw, home_win]\n",
    "    return probs[2], probs[1], probs[0]  # home_win, draw, away_win\n",
    "\n",
    "def simulate_match(home, away, neutral=True):\n",
    "    \"\"\"Sample a result. Returns (home_goals, away_goals) — simplified.\"\"\"\n",
    "    p_home, p_draw, p_away = predict_probs(home, away, neutral)\n",
    "    outcome = np.random.choice([1, 0, -1], p=[p_home, p_draw, p_away])\n",
    "    return outcome\n",
    "\n",
    "def simulate_knockout_match(home, away):\n",
    "    \"\"\"Knockout — no draws. If draw sampled, go to 50/50 extra time.\"\"\"\n",
    "    outcome = simulate_match(home, away, neutral=True)\n",
    "    if outcome == 0:\n",
    "        outcome = np.random.choice([1, -1])\n",
    "    return home if outcome == 1 else away\n",
    "\n",
    "# ── Group stage ───────────────────────────────────────────────────────\n",
    "\n",
    "def simulate_group(teams):\n",
    "    \"\"\"Simulate one group. Returns standings sorted by points.\"\"\"\n",
    "    standings = {t: {'pts': 0, 'gd': 0, 'gf': 0} for t in teams}\n",
    "\n",
    "    for home, away in combinations(teams, 2):\n",
    "        p_home, p_draw, p_away = predict_probs(home, away, neutral=True)\n",
    "        outcome = np.random.choice([1, 0, -1], p=[p_home, p_draw, p_away])\n",
    "\n",
    "        # Simulate rough goal counts for tiebreaking\n",
    "        home_goals = np.random.poisson(1.3 if outcome == 1 else 0.9)\n",
    "        away_goals = np.random.poisson(1.3 if outcome == -1 else 0.9)\n",
    "        if outcome == 0:\n",
    "            home_goals = away_goals = np.random.poisson(0.9)\n",
    "\n",
    "        if outcome == 1:\n",
    "            standings[home]['pts'] += 3\n",
    "        elif outcome == -1:\n",
    "            standings[away]['pts'] += 3\n",
    "        else:\n",
    "            standings[home]['pts'] += 1\n",
    "            standings[away]['pts'] += 1\n",
    "\n",
    "        standings[home]['gd'] += home_goals - away_goals\n",
    "        standings[away]['gd'] += away_goals - home_goals\n",
    "        standings[home]['gf'] += home_goals\n",
    "        standings[away]['gf'] += away_goals\n",
    "\n",
    "    # Sort: points → goal difference → goals scored\n",
    "    sorted_teams = sorted(teams,\n",
    "        key=lambda t: (standings[t]['pts'],\n",
    "                       standings[t]['gd'],\n",
    "                       standings[t]['gf']),\n",
    "        reverse=True)\n",
    "\n",
    "    return sorted_teams, standings\n",
    "\n",
    "# ── Full tournament ───────────────────────────────────────────────────\n",
    "\n",
    "def simulate_tournament():\n",
    "    \"\"\"Run one full tournament. Returns the winner.\"\"\"\n",
    "    # Group stage\n",
    "    group_results = {}\n",
    "    all_third = []\n",
    "\n",
    "    for group_name, teams in GROUPS.items():\n",
    "        sorted_teams, standings = simulate_group(teams)\n",
    "        group_results[group_name] = sorted_teams\n",
    "        all_third.append((sorted_teams[2],\n",
    "                          standings[sorted_teams[2]]['pts'],\n",
    "                          standings[sorted_teams[2]]['gd'],\n",
    "                          standings[sorted_teams[2]]['gf']))\n",
    "\n",
    "    # Best 8 third-place teams advance\n",
    "    all_third_sorted = sorted(all_third,\n",
    "                               key=lambda x: (x[1], x[2], x[3]),\n",
    "                               reverse=True)\n",
    "    third_qualifiers = [t[0] for t in all_third_sorted[:8]]\n",
    "\n",
    "    # Build round of 32\n",
    "    r32 = []\n",
    "    for group_name, sorted_teams in group_results.items():\n",
    "        r32.append(sorted_teams[0])  # group winners\n",
    "        r32.append(sorted_teams[1])  # group runners-up\n",
    "    r32 += third_qualifiers\n",
    "\n",
    "    # Shuffle into bracket pairs (simplified — no fixed bracket seeding)\n",
    "    np.random.shuffle(r32)\n",
    "    bracket = r32\n",
    "\n",
    "    # Knockout rounds\n",
    "    while len(bracket) > 1:\n",
    "        next_round = []\n",
    "        for i in range(0, len(bracket), 2):\n",
    "            winner = simulate_knockout_match(bracket[i], bracket[i+1])\n",
    "            next_round.append(winner)\n",
    "        bracket = next_round\n",
    "\n",
    "    return bracket[0]\n",
    "\n",
    "# ── Monte Carlo ───────────────────────────────────────────────────────\n",
    "\n",
    "N_SIMS = 10_000\n",
    "print(f'Running {N_SIMS:,} simulations...')\n",
    "\n",
    "win_counts = {}\n",
    "for _ in range(N_SIMS):\n",
    "    winner = simulate_tournament()\n",
    "    win_counts[winner] = win_counts.get(winner, 0) + 1\n",
    "\n",
    "# Results\n",
    "results_df = (pd.DataFrame.from_dict(win_counts, orient='index', columns=['wins'])\n",
    "              .sort_values('wins', ascending=False)\n",
    "              .reset_index()\n",
    "              .rename(columns={'index': 'team'}))\n",
    "results_df['win_pct'] = (results_df['wins'] / N_SIMS * 100).round(1)\n",
    "\n",
    "print('\\nWorld Cup 2026 — Win Probabilities')\n",
    "print(results_df.to_string(index=False))"
   ]
