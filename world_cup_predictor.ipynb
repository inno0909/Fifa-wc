   "source": [
    "df['elo_bucket'] = pd.cut(df['elo_diff'], \n",
    "                           bins=range(-600, 700, 100), \n",
    "                           labels=range(-550, 650, 100))\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 5))\n",
    "\n",
    "for outcome, label, color in [(1, 'Home win', 'steelblue'), \n",
    "                               (0, 'Draw', 'gray'), \n",
    "                               (-1, 'Away win', 'darkorange')]:\n",
    "    rates = df.groupby('elo_bucket')['outcome'].apply(\n",
    "        lambda x: (x == outcome).mean()\n",
    "    ).reset_index()\n",
    "    rates.columns = ['elo_bucket', 'rate']\n",
    "    ax.plot(rates['elo_bucket'], rates['rate'], \n",
    "            marker='o', label=label, color=color)\n",
    "\n",
    "ax.axvline(0, linestyle='--', color='red', alpha=0.3)\n",
    "ax.set_title('Outcome Probabilities by ELO Difference', fontsize=13)\n",
    "ax.set_xlabel('ELO Difference (Home − Away)')\n",
    "ax.set_ylabel('Probability')\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7652424a",
   "metadata": {},
   "source": [
    "ELO difference is a strong, clean predictor of match outcomes. The \n",
    "S-curve is smooth and monotonic across the full range. Three things to \n",
    "carry forward: home advantage is real (+50 ELO crossover) but irrelevant \n",
    "for World Cup prediction since all fixtures are neutral; draws peak at \n",
    "27% for evenly matched teams and will be the model's hardest prediction; \n",
    "and a handful of micro-nation blowouts exist in the data but don't \n",
    "meaningfully affect ELO ratings."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d7c7ca40",
   "metadata": {},
   "source": [
    "## How efficient are ELO ratings in predicting WC winners?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "be4773f5",
   "metadata": {},
   "outputs": [],
   "source": [
    "wc_winners = {\n",
    "    1930: 'Uruguay', 1934: 'Italy', 1938: 'Italy', 1950: 'Uruguay',\n",
    "    1954: 'Germany', 1958: 'Brazil', 1962: 'Brazil', 1966: 'England',\n",
    "    1970: 'Brazil', 1974: 'Germany', 1978: 'Argentina', 1982: 'Italy',\n",
    "    1986: 'Argentina', 1990: 'Germany', 1994: 'Brazil', 1998: 'France',\n",
    "    2002: 'Brazil', 2006: 'Italy', 2010: 'Spain', 2014: 'Germany',\n",
    "    2018: 'France', 2022: 'Argentina'\n",
    "}\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "62b15468",
   "metadata": {},
   "outputs": [],
   "source": [
    "rows = []\n",
    "for year, winner in wc_winners.items():\n",
    "    year_matches = wc[wc['year'] == year]\n",
    "    \n",
    "    home = year_matches[year_matches['home_team'] == winner][['home_elo']].rename(columns={'home_elo': 'elo'})\n",
    "    away = year_matches[year_matches['away_team'] == winner][['away_elo']].rename(columns={'away_elo': 'elo'})\n",
    "    all_elos = pd.concat([home, away])\n",
    "    if all_elos.empty:\n",
    "        continue\n",
    "\n",
    "    max_home = year_matches[['home_team', 'home_elo']].rename(columns={'home_team': 'team', 'home_elo': 'elo'})\n",
    "    max_away = year_matches[['away_team', 'away_elo']].rename(columns={'away_team': 'team', 'away_elo': 'elo'})\n",
    "    all_teams = pd.concat([max_home, max_away])\n",
    "    \n",
    "    # Fix: use iloc[0] after sorting to always get a single row\n",
    "    top = all_teams.sort_values('elo', ascending=False).iloc[0]\n",
    "\n",
    "    rows.append({\n",
    "        'year':        year,\n",
